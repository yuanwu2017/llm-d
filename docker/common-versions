# ============================================================================
# vLLM Version Configuration
# ============================================================================
# Used by CUDA and CPU platforms
VLLM_REPO=https://github.com/neuralmagic/vllm.git
VLLM_COMMIT_SHA=693c2d11ece54ace6bfaa670998f58707339e82f # maps to elvir + matejs's cherrypicks on top of v0.19.1,
# see: https://github.com/elvircrn/vllm/commits/llmd-0.19.1-nan-fixes/
# see: https://github.com/vllm-project/vllm/pull/39213

# ============================================================================
# Cuda specific configs
# ============================================================================

### Precompiled wheel settings

# CUDA-only configurations for precompiled binaries
VLLM_PREBUILT=0                # 0=editable install, 1=use full prebuilt wheel
VLLM_USE_PRECOMPILED=1         # 1=use precompiled binaries either from VLLM_COMMIT_SHA or VLLM_PRECOMPILED_WHEEL_COMMIT, 0=compile from source
# If building vLLM from a precompiled commit in the vLLM wheel index (only commits off main),
# which commit to use as the base for the compiled bits.
VLLM_PRECOMPILED_WHEEL_COMMIT=b1388b1fbf5aaef47937fabe98931211684666a6 # maps to vLLM official 0.19.1 release



# Used by XPU. The Makefile's xpu-prepare target clones VLLM_XPU_REPO and
# checks out VLLM_XPU_COMMIT_SHA.
# Currently maps to vllm-project/vllm v0.19.1.
VLLM_XPU_REPO=https://github.com/vllm-project/vllm.git
VLLM_XPU_COMMIT_SHA=b1388b1fbf5aaef47937fabe98931211684666a6

# ============================================================================
# CUDA Version Configuration
# ============================================================================
# Used by CUDA builds (Dockerfile.cuda, Dockerfile.rdma-tools)
CUDA_MAJOR=13
CUDA_MINOR=0
CUDA_PATCH=2

### GB200-specific overrides
GB200_NVSHMEM_VERSION=v3.4.5-0
GB200_DEEPEP_REPO=https://github.com/fzyzcjy/DeepEP
GB200_DEEPEP_VERSION=gb200_blog_part_2
GB200_INSTALL_OFFLOADING_CONNECTOR=false

### Offloading connector
LLM_D_OFFLOADING_CONNECTOR_VERSION=0.19
INSTALL_OFFLOADING_CONNECTOR=true
